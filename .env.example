# prtkl environment variables
# Copy to .env.production and fill in values.

# Ollama URL — defaults to the ollama container in docker-compose
PRTKL_OLLAMA_URL=http://ollama:11434

# Ollama model for word-to-pose translation
PRTKL_OLLAMA_MODEL=llama3.2:3b

# Cloudflare API token (for DNS management, not needed at runtime)
# CLOUDFLARE_API_TOKEN=
